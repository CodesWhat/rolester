{
  "name": "rolester",
  "version": "0.2.4",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "description": "Agentic job-search workspace for finding, vetting, tailoring, tracking, and preparing for roles.",
  "author": "CodesWhat",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CodesWhat/rolester.git"
  },
  "homepage": "https://github.com/CodesWhat/rolester#readme",
  "bugs": {
    "url": "https://github.com/CodesWhat/rolester/issues"
  },
  "bin": {
    "rolester": "bin/rolester.mjs"
  },
  "workspaces": [
    "website"
  ],
  "engines": {
    "node": ">=18"
  },
  "files": [
    "bin",
    "src",
    "config/*.schema.json",
    "config/*.example.*",
    "templates",
    ".agents/skills/apply-job/SKILL.md",
    ".agents/skills/calendar-sync/SKILL.md",
    ".agents/skills/configure/SKILL.md",
    ".agents/skills/discover-companies/SKILL.md",
    ".agents/skills/email-comms/SKILL.md",
    ".agents/skills/evaluate-job/SKILL.md",
    ".agents/skills/ingest-mail/SKILL.md",
    ".agents/skills/ingest-messages/SKILL.md",
    ".agents/skills/ingest-profile/SKILL.md",
    ".agents/skills/interview-prep/SKILL.md",
    ".agents/skills/optimize-linkedin/SKILL.md",
    ".agents/skills/reevaluate-strategy/SKILL.md",
    ".agents/skills/relationship-sourcing/SKILL.md",
    ".agents/skills/research-boards/SKILL.md",
    ".agents/skills/research-comp/SKILL.md",
    ".agents/skills/research-company/SKILL.md",
    ".agents/skills/schedule-meeting/SKILL.md",
    ".agents/skills/search-jobs/SKILL.md",
    ".agents/skills/setup-searches/SKILL.md",
    ".agents/skills/sync-status/SKILL.md",
    ".agents/skills/tailor-application/SKILL.md",
    ".agents/skills/track-outcomes/SKILL.md",
    "docs/ARCHITECTURE.md",
    "docs/BROWSER.md",
    "docs/DISCLAIMER.md",
    "docs/RELEASE.md",
    "docs/ROADMAP.md",
    "docs/SETUP.md",
    "docs/SOURCES.md",
    "docs/foundations-spec.md",
    "examples",
    "assets",
    "fonts",
    "scripts/install-skills.mjs",
    "AGENTS.md",
    "CLAUDE.md",
    "DATA_CONTRACT.md",
    "README.md"
  ],
  "scripts": {
    "postinstall": "node scripts/install-skills.mjs --soft || true",
    "prepare": "lefthook install || true",
    "dev": "turbo dev",
    "build": "turbo build",
    "web:dev": "npm --workspace website run dev",
    "web:build": "npm --workspace website run build",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "install-skills": "node scripts/install-skills.mjs",
    "install-skills:check": "node scripts/install-skills.mjs --check",
    "doctor": "node src/cli/doctor.mjs",
    "doctor:json": "node src/cli/doctor.mjs --json",
    "ingest": "node src/cli/ingest.mjs",
    "searches": "node src/cli/searches.mjs",
    "companies": "node src/cli/companies.mjs",
    "evaluate": "node src/cli/evaluate.mjs",
    "tracker": "node src/cli/tracker.mjs",
    "tracker:dev": "node src/cli/tracker-dev.mjs",
    "build:demo": "node scripts/build-demo.mjs",
    "deploy:demo": "node scripts/deploy-demo.mjs",
    "deploy:web": "node scripts/deploy-web.mjs",
    "gate": "node src/cli/gate.mjs",
    "learnings": "node src/cli/learnings.mjs",
    "activity": "node src/cli/activity.mjs",
    "research": "node src/cli/research.mjs",
    "stories": "node src/cli/stories.mjs",
    "strategy-review": "node src/cli/strategy-review.mjs",
    "analytics": "node src/cli/analytics.mjs",
    "evidence": "node src/cli/evidence.mjs",
    "modes": "node src/cli/modes.mjs",
    "automation": "node src/cli/automation.mjs",
    "status:map": "node src/cli/status-map.mjs",
    "export": "node src/cli/export.mjs",
    "lint:placeholders": "node src/cli/lint-placeholders.mjs",
    "test": "node --test",
    "scan:sourced": "node scripts/scan-sourced.mjs",
    "delta:sourced": "node scripts/delta-sourced.mjs",
    "capture:board": "node scripts/capture-board-snapshot.mjs",
    "capture:search-sources": "node scripts/capture-search-sources.mjs",
    "check:jobs": "node scripts/check-job-links.mjs",
    "verify:tracker": "node scripts/verify-tracker.mjs",
    "analyze:outcomes": "node scripts/analyze-outcomes.mjs",
    "calibrate:style": "node scripts/calibrate-writing-style.mjs"
  },
  "keywords": [
    "job-search",
    "career",
    "resume",
    "agentic",
    "codex",
    "automation"
  ],
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "lefthook": "^2.1.9",
    "playwright": "^1.60.0",
    "turbo": "^2.9.18"
  }
}
