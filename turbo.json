{
  "$schema": "https://turbo.build/schema.json",
  "globalPassThroughEnv": [
    "PROGRAMFILES",
    "PROGRAMFILES(X86)",
    "BOARD_BROWSER",
    "ROLESTER_DEV_PORT",
    "PATHEXT"
  ],
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "out/**"]
    }
  }
}
